<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SampleVault - Mis Sonidos</title>
    <link rel="stylesheet" href="https://www.w3schools.com/w3css/4/w3.css">
    <link rel="stylesheet" href="../css/style.css">
    <link rel="icon" type="image/png" href="../img/favicon.png">
</head>

<body>

    <header class="w3-bar w3-black w3-border-bottom w3-border-dark-grey">
        <span class="w3-bar-item w3-text-yellow"><b>SAMPLEVAULT</b></span>
        <button class="w3-bar-item w3-button w3-right btn-logout">Salir</button>
    </header>

    <main class="w3-container w3-padding-32">
        <div class="w3-row-padding">

            <section class="w3-col l4 m5 s12">
                <div class="w3-card-4 vault-card w3-padding w3-round">
                    <h3 class="w3-text-yellow">Subir Nuevo Sample</h3>
                    <form id="uploadForm">
                        <label for="display_name">Nombre del Sonido</label>
                        <input class="w3-input w3-border w3-round w3-transparent w3-text-white" type="text"
                            id="display_name" placeholder="Ej: Kick Pesado 808" required maxlength="100">

                        <label for="category" class="w3-margin-top">Categoría</label>
                        <select class="w3-select w3-border w3-round w3-black w3-text-white" id="category" required>
                            <option value="">-- Seleccionar --</option>
                            <option value="Kick">Kick (Bombo)</option>
                            <option value="Snare">Snare (Redoblante)</option>
                            <option value="Hi-Hat">Hi-Hat</option>
                            <option value="Loop">Melody Loop</option>
                            <option value="FX">Efectos (FX)</option>
                        </select>

                        <label for="bpm" class="w3-margin-top">BPM (Opcional)</label>
                        <input class="w3-input w3-border w3-round w3-transparent w3-text-white" type="number" id="bpm"
                            value="120" min="40" max="300">

                        <label for="audioFile" class="w3-margin-top">Archivo de Audio</label>
                        <input class="w3-input w3-border w3-round" type="file" id="audioFile"
                            accept=".mp3,.wav,.ogg,.flac" required>

                        <button type="submit" class="w3-button w3-yellow w3-block w3-round-large w3-margin-top"
                            id="submitBtn">
                            <b>CARGAR A LA BIBLIOTECA</b>
                        </button>
                    </form>
                </div>
            </section>

            <section class="w3-col l8 m7 s12">
                <h3 class="w3-text-white">Mi Biblioteca Privada</h3>
                <div class="w3-responsive">
                    <table class="w3-table w3-striped w3-bordered vault-card">
                        <thead>
                            <tr class="w3-yellow">
                                <th>Nombre</th>
                                <th>Categoría</th>
                                <th>BPM</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="samplesTableBody">
                        </tbody>
                    </table>
                </div>
            </section>

        </div>
    </main>

    <script src="../js/services/apiService.js"></script>
    <script src="../js/frontControllers/samplesFrontController.js"></script>
</body>

</html>